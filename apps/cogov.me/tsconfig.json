{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"esModuleInterop": true,
		"target": "ESNext",
		"module": "ESNext",
		"jsxImportSource": "solid-js",
		"jsx": "preserve",
		"lib": ["ESNext", "dom"],
		"moduleResolution": "node",
		"types": [
			"node",
			"vite/client"
		],
		"typeRoots": [
			"node_modules/@types"
		]
	}
}
