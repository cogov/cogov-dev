{
	"name": "@cogov/home",
	"description": "cogov.tech site",
	"version": "0.0.1",
	"scripts": {
		"dev": "./node_modules/.bin/sapper dev",
		"build": "./node_modules/.bin/sapper build --legacy",
		"export": "./node_modules/.bin/sapper export --legacy",
		"start": "node __sapper__/build",
		"cy:run": "cypress run",
		"cy:open": "cypress open",
		"test": "run-p --race dev cy:run",
		"publish:hostgator": "NODE_ENV=production npm run export && rm -rf __sapper__/export/assets && npm run put:hostgator",
		"publishall:hostgator": "NODE_ENV=production npm run export && npm run put:hostgator",
		"put:hostgator": "sftp -P 2222 cogov@cogov.tech < publish-hostgator-input.txt",
		"ftp:mkdir": "npm run export && find  __sapper__/export -type d | sed -n '1!p' | sed 's/__sapper__\\/export\\///g' | awk '{print \"mkdir public_html/\"$1}' | sftp -P 2222 cogov@cogov.tech",
		"ftp": "echo \"cd public_html\" | ftp -P 2222 cogov@cogov.tech"
	},
	"dependencies": {
		"@cogov/home-ui": "^0.0.1",
		"@ctx-core/array": "^15.5.22",
		"@ctx-core/object": "^8.0.15",
		"compression": "^1.7.4",
		"esm": "^3.2.25",
		"polka": "next",
		"sirv": "^0.4.6"
	},
	"devDependencies": {
		"@babel/core": "^7.10.2",
		"@babel/plugin-syntax-dynamic-import": "^7.8.3",
		"@babel/plugin-transform-runtime": "^7.10.1",
		"@babel/preset-env": "^7.10.2",
		"@babel/runtime": "^7.10.2",
		"@cogov/home-scss": "^0.0.1",
		"@ctx-core/sass": "^6.4.35",
		"@ctx-core/svelte": "^5.3.19",
		"@rollup/plugin-babel": "^5.0.3",
		"@rollup/plugin-commonjs": "^13.0.0",
		"@rollup/plugin-node-resolve": "^8.0.1",
		"@rollup/plugin-replace": "^2.3.3",
		"npm-run-all": "^4.1.5",
		"rollup": "^2.15.0",
		"rollup-plugin-node-builtins": "^2.1.2",
		"rollup-plugin-node-globals": "^1.4.0",
		"rollup-plugin-svelte": "^5.2.2",
		"rollup-plugin-terser": "^6.1.0",
		"sapper": "^0.27.14",
		"svelte": "^3.23.1"
	}
}