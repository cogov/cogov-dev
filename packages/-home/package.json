{
	"name": "@cogov/home",
	"description": "cogov.tech site",
	"version": "0.0.1",
	"scripts": {
		"dev": "sapper dev",
		"build": "sapper build --legacy",
		"export": "sapper export --legacy",
		"start": "node __sapper__/build",
		"cy:run": "cypress run",
		"cy:open": "cypress open",
		"test": "run-p --race dev cy:run",
		"publish:hostgator": "NODE_ENV=production npm run export && $FILES=$(mktemp) && find ./__sapper__/export/* | grep -v ./__sapper__/export/assets/ > $FILES && rsync --port=2222 -zrp --files-from=$FILES cogov@cogov.tech",
		"publishall:hostgator": "NODE_ENV=production  npm run export && rsync --port=2222 -zrp ./__sapper__/export/ cogov@cogov.tech",
		"ftp": "echo \"cd public_html\" | ftp -P 2222 cogov@cogov.tech"
	},
	"dependencies": {
		"@cogov/home-ui": "^0.0.1",
		"@ctx-core/array": "^15.5.21",
		"@ctx-core/object": "^8.0.14",
		"compression": "^1.7.4",
		"esm": "^3.2.25",
		"polka": "next",
		"sirv": "^0.4.6"
	},
	"devDependencies": {
		"@babel/core": "^7.10.1",
		"@babel/plugin-syntax-dynamic-import": "^7.8.3",
		"@babel/plugin-transform-runtime": "^7.10.1",
		"@babel/preset-env": "^7.10.1",
		"@babel/runtime": "^7.10.1",
		"@cogov/home-scss": "^0.0.1",
		"@ctx-core/sass": "^6.4.34",
		"@ctx-core/svelte": "^5.3.18",
		"@rollup/plugin-babel": "^5.0.2",
		"@rollup/plugin-commonjs": "^12.0.0",
		"@rollup/plugin-node-resolve": "^8.0.0",
		"@rollup/plugin-replace": "^2.3.2",
		"npm-run-all": "^4.1.5",
		"rollup": "^2.11.2",
		"rollup-plugin-node-builtins": "^2.1.2",
		"rollup-plugin-node-globals": "^1.4.0",
		"rollup-plugin-svelte": "^5.2.2",
		"rollup-plugin-terser": "^6.1.0",
		"sapper": "^0.27.13",
		"svelte": "^3.23.0"
	}
}